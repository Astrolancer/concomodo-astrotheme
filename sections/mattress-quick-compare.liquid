{%- liquid
  assign count = 0
  for i in (1..4)
    assign key = 'product_' | append: i
    assign prod = section.settings[key]
    if prod != blank
      assign count = count | plus: 1
    endif
  endfor
-%}

{%- if count > 0 -%}
  <div class="section-background color-{{ section.settings.color_scheme }}"></div>
  <div
    class="section section--{{ section.settings.section_width }} qcompare color-{{ section.settings.color_scheme }} spacing-style"
    style="{% render 'spacing-style', settings: section.settings %} --qc-radius: {{ section.settings.corner_radius }}px; --qc-cols: {{ count }};"
    {% if request.visual_preview_mode %}data-shopify-visual-preview{% endif %}
  >
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="qcompare__header">
        {%- if section.settings.heading != blank -%}
          <h2 class="qcompare__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <div class="qcompare__subheading">{{ section.settings.subheading }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="qcompare__grid">
      {%- for i in (1..4) -%}
        {%- liquid
          assign key = 'product_' | append: i
          assign product = section.settings[key]
          if product == blank
            continue
          endif
          assign spec = product.metafields.custom.comparison.value
          assign is_highlight = false
          if section.settings.highlight == i
            assign is_highlight = true
          endif
          assign min_price = 0
          for v in product.variants
            if v.price > 0 and min_price == 0
              assign min_price = v.price
            elsif v.price > 0 and v.price < min_price
              assign min_price = v.price
            endif
          endfor
        -%}
        <div class="qcompare__card{% if is_highlight %} qcompare__card--highlight{% endif %}">
          {%- if is_highlight and section.settings.highlight_badge != blank -%}
            <span class="qcompare__badge">{{ section.settings.highlight_badge }}</span>
          {%- elsif spec.badge != blank -%}
            <span class="qcompare__badge qcompare__badge--soft">{{ spec.badge }}</span>
          {%- endif -%}

          <a href="{{ product.url }}" class="qcompare__title">{{ product.title }}</a>

          {%- assign feel = spec.feel_title | default: spec.firmness_label -%}
          {%- if feel != blank -%}
            <div class="qcompare__feel">{{ feel }}</div>
          {%- endif -%}

          {%- if min_price > 0 -%}
            <div class="qcompare__price">
              <span class="qcompare__price-from">{{ section.settings.price_prefix }}</span>
              {{ min_price | money }}
            </div>
          {%- endif -%}

          <a href="{{ product.url }}" class="qcompare__cta button{% unless is_highlight %} button-secondary{% endunless %}">
            {{ section.settings.cta_label | default: 'Scopri' }}
          </a>

          <ul class="qcompare__specs" role="list">
            {%- if section.settings.show_firmness and spec.firmness_value != blank -%}
              <li class="qcompare__spec">
                <span class="qcompare__spec-label">{{ section.settings.firmness_label }}</span>
                {% render 'qcompare-meter', value: spec.firmness_value %}
              </li>
            {%- endif -%}
            {%- if section.settings.show_support and spec.support_value != blank -%}
              <li class="qcompare__spec">
                <span class="qcompare__spec-label">{{ section.settings.support_label }}</span>
                {% render 'qcompare-meter', value: spec.support_value %}
              </li>
            {%- endif -%}
            {%- if section.settings.show_cooling and spec.cooling_value != blank -%}
              <li class="qcompare__spec">
                <span class="qcompare__spec-label">{{ section.settings.cooling_label }}</span>
                {% render 'qcompare-meter', value: spec.cooling_value %}
              </li>
            {%- endif -%}
            {%- if section.settings.show_height and spec.height_value != blank -%}
              <li class="qcompare__spec qcompare__spec--value">
                <span class="qcompare__spec-label">{{ section.settings.height_label }}</span>
                <span class="qcompare__spec-value">{{ spec.height_value }}</span>
              </li>
            {%- endif -%}
            {%- if section.settings.show_layers and spec.layers_count != blank -%}
              <li class="qcompare__spec qcompare__spec--value">
                <span class="qcompare__spec-label">{{ section.settings.layers_label }}</span>
                <span class="qcompare__spec-value">{{ spec.layers_count }}</span>
              </li>
            {%- endif -%}
          </ul>
        </div>
      {%- endfor -%}
    </div>
  </div>

{%- elsif request.design_mode -%}
  <div class="section section--page-width color-{{ section.settings.color_scheme }} spacing-style">
    <div class="qcompare__placeholder">Seleziona da 2 a 4 materassi nelle impostazioni della sezione per costruire il comparatore. I dati (sensazione, supporto, traspirabilità, altezza, strati) vengono letti dal metaobject <code>custom.comparison</code> di ogni prodotto.</div>
  </div>
{%- endif -%}

{% stylesheet %}
  .qcompare {
    --qc-radius: 24px;
    --qc-line: rgb(var(--color-foreground-rgb) / 0.12);
    --qc-fill: rgb(var(--color-foreground-rgb) / 0.55);
  }

  .qcompare__header {
    text-align: center;
    max-width: 680px;
    margin: 0 auto 2.5rem;
  }

  .qcompare__heading { margin: 0 0 0.75rem; }
  .qcompare__subheading { opacity: 0.8; line-height: 1.5; }
  .qcompare__subheading > :first-child { margin-block-start: 0; }
  .qcompare__subheading > :last-child { margin-block-end: 0; }

  .qcompare__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    max-width: 1100px;
    margin-inline: auto;
  }

  @media screen and (min-width: 600px) {
    .qcompare__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 900px) {
    .qcompare__grid {
      grid-template-columns: repeat(var(--qc-cols, 4), 1fr);
    }
  }

  .qcompare__card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: clamp(1.25rem, 2.5vw, 1.75rem);
    border: 1px solid var(--qc-line);
    border-radius: var(--qc-radius);
    background: var(--color-background);
  }

  .qcompare__card--highlight {
    border-color: rgb(var(--color-foreground-rgb) / 0.55);
    box-shadow: 0 18px 44px rgb(var(--color-foreground-rgb) / 0.1);
  }

  .qcompare__badge {
    position: absolute;
    inset-block-start: -0.75rem;
    inset-inline-start: 1.25rem;
    padding: 0.3em 0.8em;
    border-radius: 999px;
    background: var(--color-foreground);
    color: var(--color-background);
    font-size: 0.75rem;
    font-weight: 600;
  }

  .qcompare__badge--soft {
    background: rgb(var(--color-foreground-rgb) / 0.1);
    color: inherit;
  }

  .qcompare__title {
    font-size: 1.3em;
    font-weight: 700;
    text-decoration: none;
    color: inherit;
  }

  .qcompare__feel {
    font-size: 0.9em;
    opacity: 0.7;
  }

  .qcompare__price {
    font-size: 1.2em;
    font-weight: 700;
  }

  .qcompare__price-from {
    font-size: 0.7em;
    font-weight: 400;
    opacity: 0.7;
    margin-inline-end: 0.25rem;
  }

  .qcompare__cta {
    margin-block: 0.4rem 0.6rem;
    text-align: center;
    text-decoration: none;
  }

  .qcompare__specs {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin: 0;
    padding-block-start: 0.75rem;
    border-block-start: 1px solid var(--qc-line);
    list-style: none;
  }

  .qcompare__spec {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .qcompare__spec--value {
    flex-direction: row;
    justify-content: space-between;
    align-items: baseline;
  }

  .qcompare__spec-label {
    font-size: 0.85em;
    opacity: 0.7;
  }

  .qcompare__spec-value {
    font-weight: 600;
  }

  .qcompare__meter {
    display: flex;
    gap: 4px;
  }

  .qcompare__meter-seg {
    position: relative;
    flex: 1;
    height: 6px;
    border-radius: 999px;
    background: rgb(var(--color-foreground-rgb) / 0.12);
    overflow: hidden;
  }

  .qcompare__meter-seg::before {
    content: '';
    position: absolute;
    inset: 0;
    width: var(--f, 0%);
    border-radius: inherit;
    background: var(--qc-fill);
  }

  .qcompare__placeholder {
    padding: 2rem;
    border: 1px dashed var(--qc-line, rgb(var(--color-foreground-rgb) / 0.3));
    border-radius: 12px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Comparatore materassi",
  "tag": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Titolo",
      "default": "Confronta i nostri materassi"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Sottotitolo",
      "default": "<p>Quattro modelli, una sola cosa in comune: dormire meglio. Trova quello giusto per te.</p>"
    },
    {
      "type": "header",
      "content": "Materassi (da 2 a 4)"
    },
    { "type": "product", "id": "product_1", "label": "Materasso 1" },
    { "type": "product", "id": "product_2", "label": "Materasso 2" },
    { "type": "product", "id": "product_3", "label": "Materasso 3" },
    { "type": "product", "id": "product_4", "label": "Materasso 4" },
    {
      "type": "header",
      "content": "Righe di confronto"
    },
    { "type": "checkbox", "id": "show_firmness", "label": "Durezza", "default": true },
    { "type": "text", "id": "firmness_label", "label": "Etichetta durezza", "default": "Durezza" },
    { "type": "checkbox", "id": "show_support", "label": "Supporto", "default": true },
    { "type": "text", "id": "support_label", "label": "Etichetta supporto", "default": "Supporto" },
    { "type": "checkbox", "id": "show_cooling", "label": "Traspirabilità", "default": true },
    { "type": "text", "id": "cooling_label", "label": "Etichetta traspirabilità", "default": "Traspirabilità" },
    { "type": "checkbox", "id": "show_height", "label": "Altezza", "default": true },
    { "type": "text", "id": "height_label", "label": "Etichetta altezza", "default": "Altezza" },
    { "type": "checkbox", "id": "show_layers", "label": "Strati", "default": false },
    { "type": "text", "id": "layers_label", "label": "Etichetta strati", "default": "Strati" },
    {
      "type": "header",
      "content": "Prezzo e CTA"
    },
    { "type": "text", "id": "price_prefix", "label": "Testo prima del prezzo", "default": "da" },
    { "type": "text", "id": "cta_label", "label": "Testo pulsante", "default": "Scopri" },
    {
      "type": "range",
      "id": "highlight",
      "label": "Evidenzia colonna (0 = nessuna)",
      "min": 0,
      "max": 4,
      "step": 1,
      "default": 0
    },
    { "type": "text", "id": "highlight_badge", "label": "Etichetta colonna evidenziata", "default": "Più venduto" },
    {
      "type": "header",
      "content": "Sezione"
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "Raggio angoli",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Larghezza sezione",
      "options": [
        { "value": "page-width", "label": "Pagina" },
        { "value": "full-width", "label": "Piena" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Schema colore",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Spaziatura"
    },
    { "type": "range", "id": "padding-block-start", "label": "Sopra", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding-block-end", "label": "Sotto", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding-inline-start", "label": "Sinistra", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding-inline-end", "label": "Destra", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 }
  ],
  "presets": [
    {
      "name": "Comparatore materassi"
    }
  ]
}
{% endschema %}
