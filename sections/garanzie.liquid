          "info": "Es. «garanzia-10-anni» → /pages/garanzie#garanzia-10-anni. Se vuota, viene generata dal titolo."
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icona",
          "options": [
            { "value": "moon", "label": "Luna (prova)" },
            { "value": "shield", "label": "Scudo (garanzia)" },
            { "value": "truck", "label": "Furgone (consegna)" },
            { "value": "swap", "label": "Frecce (cambio)" },
            { "value": "heart", "label": "Cuore" }
          ],
          "default": "shield"
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Etichetta piccola"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titolo",
          "default": "La garanzia"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Testo"
        },
        {
          "type": "textarea",
          "id": "points",
          "label": "Punti chiave (uno per riga)"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Testo link"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Garanzie",
      "blocks": [
        { "type": "guarantee" }
      ]
    }
  ]
}
{% endschema %}
