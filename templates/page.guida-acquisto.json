        "faq_sostituzione": {
          "type": "faq",
          "settings": {
            "question": "Ogni quanto va sostituito il materasso?",
            "answer": "<p>In media ogni 8–10 anni. Se ti svegli indolenzito, noti avvallamenti o il materasso ha perso elasticità, è il momento di cambiarlo. I materassi concomodo sono garantiti fino a 10 anni.</p>"
          }
        },
        "faq_prova": {
          "type": "faq",
          "settings": {
            "question": "Come funzionano le 100 notti di prova?",
            "answer": "<p>Dormi sul tuo nuovo materasso per 100 notti: al corpo servono alcune settimane per adattarsi. Se entro i 100 giorni non sei convinto, ti rimborsiamo. Semplice, senza rischi.</p>"
          }
        },
        "faq_sfoderabile": {
          "type": "faq",
          "settings": {
            "question": "I materassi sono sfoderabili e lavabili?",
            "answer": "<p>I modelli Morbido, Sostegno e Sostegno ibrido sono completamente sfoderabili e il rivestimento è lavabile. Il Compatto ha un rivestimento fisso in tessuto traspirante 3D Air.</p>"
          }
        },
        "faq_rete": {
          "type": "faq",
          "settings": {
            "question": "Su quale rete posso usarli?",
            "answer": "<p>Su qualsiasi rete a doghe in buono stato, fissa o motorizzata. L'importante è che le doghe siano ravvicinate e non cedevoli, per dare al materasso una base uniforme.</p>"
          }
        },
