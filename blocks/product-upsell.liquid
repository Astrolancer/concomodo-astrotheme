{%- doc -%}
  Product page upsell with a guided choice:

  - Two toppers in mutually exclusive choice (adding one removes the other),
    each with its own benefit text, inheriting Dimensione/Misure from the main
    product like linked-size-add. Side by side on desktop, swipe carousel on
    mobile — every card shares the same surface, radius and paddings as the
    theme's product cards.
  - A gift pillow as a horizontal card: added automatically (free of charge)
    when a topper is chosen, or purchasable alone at a configurable display
    discount.

  The block renders nothing on the storefront until at least one product is
  picked in the editor. It only *shows* the promotional prices: the actual cart
  prices must be backed by two automatic discounts in the Shopify admin (see
  the schema note).
{%- enddoc -%}

{%- liquid
  assign topper_1 = block.settings.topper_1
  assign topper_2 = block.settings.topper_2
  assign gift_product = block.settings.gift_product

  assign render_toppers = false
  if block.settings.show_toppers
    if topper_1 != blank or topper_2 != blank
      assign render_toppers = true
    endif
  endif

  assign has_visible_content = render_toppers
  if gift_product != blank
    assign has_visible_content = true
  endif
-%}

{%- if has_visible_content or request.design_mode -%}
  <script src="{{ 'product-upsell.js' | asset_url }}" type="module"></script>

  <product-upsell
    class="
      product-upsell
      {% unless block.settings.inherit_color_scheme %}color-{{ block.settings.color_scheme }}{% endunless %}
      spacing-style
    "
    style="
      {% render 'spacing-style', settings: block.settings %}
      --product-upsell-card-radius: {{ block.settings.card_radius }}px;
    "
    data-section-id="{{ section.id }}"
    data-gift-enabled="{{ block.settings.gift_enabled }}"
    data-solo-percent="{{ block.settings.solo_discount_percent }}"
    data-gift-cart-property="{{ block.settings.gift_cart_property | escape }}"
    data-bundle-main="{{ block.settings.bundle_main }}"
    data-topper-products="{{ topper_1.id }},{{ topper_2.id }}"
    data-topper-keyword="{{ block.settings.topper_keyword | escape }}"
    data-mattress-keyword="{{ block.settings.mattress_keyword | escape }}"
    {{ block.shopify_attributes }}
  >
    {%- if block.settings.heading != blank -%}
      <h4 class="product-upsell__heading">{{ block.settings.heading }}</h4>
    {%- endif -%}

    {%- if block.settings.hint != blank -%}
      <p class="product-upsell__hint">{{ block.settings.hint }}</p>
    {%- endif -%}

    {%- if render_toppers -%}
      <div class="product-upsell__choice">
        {%- for i in (1..2) -%}
          {%- liquid
            assign product_key = 'topper_' | append: i
            assign badge_key = product_key | append: '_badge'
            assign text_key = product_key | append: '_text'
            assign topper_product = block.settings[product_key]
            assign topper_badge = block.settings[badge_key]
            assign topper_text = block.settings[text_key]
          -%}
          {%- if topper_product != blank -%}
            {% render 'product-upsell-item',
              product: topper_product,
              role: 'topper',
              badge: topper_badge,
              benefit: topper_text,
              add_label: block.settings.add_label,
              remove_label: block.settings.remove_label,
              unavailable_label: block.settings.unavailable_label,
              button_style: block.settings.button_style,
              card_scheme: block.settings.card_scheme
            %}
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if gift_product != blank -%}
      {% render 'product-upsell-item',
        product: gift_product,
        role: 'gift',
        benefit: block.settings.gift_text,
        add_label: block.settings.add_label,
        remove_label: block.settings.remove_label,
        unavailable_label: block.settings.unavailable_label,
        button_style: block.settings.button_style,
        card_scheme: block.settings.card_scheme,
        solo_percent: block.settings.solo_discount_percent,
        solo_badge: block.settings.solo_badge,
        gift_badge: block.settings.gift_badge,
        gift_free_label: block.settings.gift_free_label
      %}
    {%- endif -%}

    {%- if request.design_mode and has_visible_content == false -%}
      <p class="product-upsell__setup">
        Upsell prodotto: scegli il cuscino (ed eventualmente i due topper) nelle
        impostazioni del blocco. Il blocco resta invisibile sul negozio finché
        non c'è niente da mostrare.
      </p>
    {%- endif -%}
  </product-upsell>
{%- endif -%}

{% stylesheet %}
  .product-upsell {
    display: block;
    width: 100%;
  }

  .product-upsell [hidden] {
    display: none !important;
  }

  .product-upsell__heading {
    margin: 0;
    font-family: var(--font-body--family);
    font-size: 1rem;
    font-weight: 500;
  }

  .product-upsell__hint {
    margin: 4px 0 0;
    font-size: var(--font-size--xs);
    opacity: 0.7;
  }

  .product-upsell__choice {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-block-start: 12px;
  }

  .product-upsell__choice:has(> .product-upsell__card:only-child) {
    grid-template-columns: 1fr;
  }

  .product-upsell__card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 10px;
    background-color: var(--color-background);
    color: var(--color-foreground);
    border-radius: var(--product-upsell-card-radius, 30px);
    padding: 16px 16px 20px;
  }

  .product-upsell__card[data-selected] {
    box-shadow: 0 0 0 2px var(--color-primary);
  }

  .product-upsell__media {
    position: relative;
    aspect-ratio: 4 / 3;
    border-radius: 18px;
    overflow: hidden;
    background-color: rgb(var(--color-foreground-rgb) / 0.05);
  }

  .product-upsell__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-upsell__flag {
    position: absolute;
    top: 10px;
    left: 10px;
    padding: 4px 12px;
    border-radius: 100px;
    background-color: var(--color-background);
    color: var(--color-foreground);
    font-size: var(--font-size--2xs, 0.6875rem);
    font-weight: 500;
    box-shadow: 0 1px 4px rgb(0 0 0 / 0.08);
  }

  .product-upsell__body {
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1 1 auto;
    min-width: 0;
    padding-inline: 4px;
  }

  .product-upsell__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 10px;
  }

  .product-upsell__title {
    margin: 0;
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.3;
  }

  .product-upsell__price {
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 6px;
    white-space: nowrap;
  }

  .product-upsell__compare {
    font-size: var(--font-size--xs);
    opacity: 0.55;
  }

  .product-upsell__amount {
    font-size: 1rem;
    font-weight: 500;
  }

  .product-upsell__benefit {
    font-size: var(--font-size--xs);
    line-height: 1.45;
    opacity: 0.75;
  }

  .product-upsell__benefit p {
    margin: 0;
  }

  .product-upsell__meta {
    margin: 0;
    font-size: var(--font-size--xs);
    opacity: 0.6;
  }

  .product-upsell__actions {
    display: flex;
    align-items: center;
    margin-block-start: auto;
    padding-block-start: 4px;
  }

  .product-upsell__add,
  .product-upsell__card--topper .product-upsell__remove {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    width: 100%;
    min-height: 0;
    padding-block: 10px;
    padding-inline: 16px;
    font-size: var(--font-size--sm, 0.875rem);
  }

  .product-upsell__plus {
    font-weight: 600;
  }

  .product-upsell__remove svg {
    width: 14px;
    height: 14px;
  }

  .product-upsell__remove--icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: transparent;
    color: currentcolor;
    cursor: pointer;
  }

  .product-upsell__remove--icon:hover {
    background-color: rgb(var(--color-foreground-rgb) / 0.08);
  }

  .product-upsell__remove--icon svg {
    width: 18px;
    height: 18px;
  }

  /* Gift pillow: horizontal card, full width under the topper choice */
  .product-upsell__card--gift {
    flex-direction: row;
    align-items: center;
    gap: 14px;
    margin-block-start: 16px;
    padding: 14px 16px;
  }

  .product-upsell__card--gift .product-upsell__media {
    flex: 0 0 84px;
    aspect-ratio: 1;
    border-radius: 14px;
  }

  .product-upsell__card--gift .product-upsell__flag {
    top: 6px;
    left: 6px;
    padding: 2px 8px;
  }

  .product-upsell__card--gift .product-upsell__body {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    column-gap: 12px;
    row-gap: 3px;
    padding-inline: 0;
  }

  .product-upsell__card--gift .product-upsell__body > * {
    grid-column: 1;
  }

  .product-upsell__card--gift .product-upsell__actions {
    grid-column: 2;
    grid-row: 1 / span 3;
    margin: 0;
    padding: 0;
  }

  .product-upsell__card--gift .product-upsell__head {
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
  }

  .product-upsell__card--gift .product-upsell__add {
    width: auto;
  }

  /* Mobile: the topper choice becomes a swipe carousel with a peek of the next card */
  @media screen and (max-width: 749px) {
    .product-upsell__choice {
      display: flex;
      gap: 12px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding: 2px;
    }

    .product-upsell__choice::-webkit-scrollbar {
      display: none;
    }

    .product-upsell__choice .product-upsell__card {
      flex: 0 0 80%;
      scroll-snap-align: start;
    }

    .product-upsell__choice .product-upsell__card:only-child {
      flex-basis: 100%;
    }
  }

  product-upsell[data-busy] .product-upsell__add,
  product-upsell[data-busy] .product-upsell__remove {
    opacity: 0.5;
    pointer-events: none;
  }

  .product-upsell__setup {
    margin: 10px 0 0;
    padding: 12px 14px;
    font-size: var(--font-size--xs);
    border: 1px dashed rgb(var(--color-foreground-rgb) / 0.35);
    border-radius: 12px;
    opacity: 0.8;
  }
{% endstylesheet %}

{% schema %}
